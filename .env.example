# App settings
APP_NAME=goBGP Route Manager
APP_HOST=0.0.0.0
APP_PORT=8000
DB_HOST_DIR=./data

# SQLite path
DATABASE_URL=sqlite:////data/route_manager.db

# goBGP integration
GOBGP_ENABLED=false
GOBGP_BIN=gobgp
GOBGP_TIMEOUT=10
GOBGP_HOST=gobgp
GOBGP_PORT=50051
GOBGPD_API_HOSTS=127.0.0.1
GOBGP_USE_GRPC=true
GOBGP_GRPC_TIMEOUT=10
GOBGP_GRPC_FALLBACK_CLI=true
ROUTE_APPLY_WORKERS=8

# Optional: token for IPinfo API used in domain discovery
IPINFO_TOKEN=

# Latency monitoring
LATENCY_CHECK_INTERVAL_SECONDS=60
LATENCY_RETENTION_HOURS=24

# Discovery tuning
DISCOVERY_MAX_IPS=12
DISCOVERY_DNS_ATTEMPTS=4
DISCOVERY_DNS_DELAY_MS=250
DISCOVERY_IP_LOOKUP_TIMEOUT=2
DISCOVERY_PREFIX_LOOKUP_TIMEOUT=6
DISCOVERY_HTTP_RETRIES=2
DISCOVERY_RIPESTAT_TIMEOUT=10
DISCOVERY_ENABLE_BGPVIEW=false
